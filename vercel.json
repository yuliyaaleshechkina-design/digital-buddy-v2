{
  "version": 2,
  "builds": [
    {
      "src": "api/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/main.py"
    },
    {
      "src": "/(.*\\.(css|js|png|jpg|ico))",
      "dest": "/frontend/$1"
    },
    {
      "src": "/newcomer",
      "dest": "/frontend/newcomer.html"
    },
    {
      "src": "/hr",
      "dest": "/frontend/hr.html"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/index.html"
    }
  ]
}
